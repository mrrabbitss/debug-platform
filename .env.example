# Core
APP_ENV=dev
DATABASE_URL=sqlite:///./data/gw_ap_debug.db
STORAGE_ROOT=./data/storage
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional API protection. Leave blank for local development.
API_KEY=
# local (loopback development), api_key (single shared key), or rbac (per-user tokens).
AUTH_MODE=local
# In rbac mode, allow API_KEY as an emergency ADMIN credential during migration.
AUTH_ALLOW_LEGACY_ADMIN=true

# LLM: mock or openai_compatible
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
# Optional Fernet key used to encrypt model API keys saved from the web UI.
# Leave blank for local use: the backend creates backend/data/model_secret.key automatically.
MODEL_SECRET_KEY=
# Comma-separated exact hosts or suffixes such as api.example.com,.corp.example.
# Required for HTTP/loopback endpoints and for every API model endpoint in APP_ENV=prod.
MODEL_ENDPOINT_ALLOWLIST=
# Set true only when trusted private-network model hosts cannot be enumerated above.
# Loopback and link-local/metadata endpoints still require stricter checks.
MODEL_ALLOW_PRIVATE_ENDPOINTS=false

# Qwen example (replace workspace ID, region and model according to your internal approval):
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# GLM example: use the OpenAI-compatible Base URL supplied by the approved GLM service.
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://your-approved-glm-compatible-endpoint/v1
# LLM_MODEL=your-glm-model

MAX_UPLOAD_BYTES=2147483648
MAX_EXTRACTED_BYTES=8589934592
MAX_ARCHIVE_FILES=20000
PARSER_MAX_TEXT_BYTES=134217728
TOOL_TIMEOUT_SECONDS=300

# Optional Qdrant. If empty, the local hybrid retriever is used.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=gw_ap_knowledge

# Docker Compose local stack. Use a URL-safe password or override DOCKER_DATABASE_URL.
POSTGRES_USER=gwap
POSTGRES_PASSWORD=gwap-local-only
POSTGRES_DB=gwap
DOCKER_DATABASE_URL=postgresql+psycopg://gwap:gwap-local-only@postgres:5432/gwap
DOCKER_QDRANT_URL=http://qdrant:6333
BACKEND_PORT=8000
FRONTEND_PORT=8080
